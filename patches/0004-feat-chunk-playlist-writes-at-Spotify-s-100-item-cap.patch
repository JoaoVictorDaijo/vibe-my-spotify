+        uris = [f"spotify:track:t{i}" for i in range(150)]
+
+        result = add_tracks_to_playlist("pl1", uris)
+
+        assert "Added 150 tracks" in result.message
+        # Last chunk's snapshot is returned
+        assert result.snapshot_id == "s2"
